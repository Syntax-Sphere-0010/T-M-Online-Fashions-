# =============================================
#  T&M Online Fashions — Shopify Configuration
# =============================================
#  Copy this file to `.env` and fill in your
#  actual Shopify credentials when you have them.
#
#  HOW TO GET THESE VALUES:
#  1. Log in to your Shopify Admin (https://admin.shopify.com)
#  2. Go to Settings → Apps and sales channels → Develop apps
#  3. Create a new app (e.g. "T&M Storefront")
#  4. Configure Storefront API scopes:
#     - unauthenticated_read_product_listings
#     - unauthenticated_read_product_inventory
#     - unauthenticated_write_checkouts
#     - unauthenticated_read_checkouts
#  5. Install the app and copy the tokens below
# =============================================

# Your Shopify store domain (e.g. tm-online-fashions.myshopify.com)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (required for Buy SDK / storefront queries)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token-here

# Admin API credentials (optional — for future inventory sync, order management, etc.)
SHOPIFY_API_KEY=your-admin-api-key-here
SHOPIFY_API_SECRET=your-admin-api-secret-here
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-access-token-here

# =============================================
#  Additional Settings
# =============================================

# Default currency code (ISO 4217)
SHOPIFY_CURRENCY=INR

# Enable debug/mock mode (set to "false" when going live)
SHOPIFY_DEBUG_MODE=true
